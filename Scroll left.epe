{
  "name": "Scroll left",
  "id": "BJXeDFLwuRzkpKCgs",
  "sources": {
    "main": "export var speed = 0.5;\nexport var scale = 1.0;\nexport var direction = 1.0; // set to -1.0 to reverse\nvar t = 0;\n\nexport function beforeRender(delta) {\n  t += delta * speed * 0.0003 * direction;\n}\n\nexport function render(index) { // 1D fallback: fake y from index\n  var y = index / (pixelCount - 1);\n  hsv(fract(y * scale + t), 1, 1);\n}\n\nexport function render2D(index, x, y) {\n  hsv(fract(y * scale + t), 1, 1);\n}\n\nfunction fract(v){ return v - floor(v); }"
  },
  "preview": ""
}