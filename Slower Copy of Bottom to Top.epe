{
  "name": "Slower Copy of Bottom to Top",
  "id": "LC4AeXeYYBohNPCut",
  "sources": {
    "main": "// Bottom → Top Rainbow (1D + 2D)\n// Defaults: vertical axis (y), bottom→top\n\nexport var speed = 0.2;   // animation speed\nexport var scale = 0.8;   // rainbow tightness\nexport var vertical = -0;  // 1 = use Y (vertical), 0 = use X (horizontal)\nexport var direction = -1; // +1 = top→bottom, -1 = bottom→top (default)\n\nvar t = 0;\n\nexport function beforeRender(delta) {\n  // advance time; tweak the factor if you want global faster/slower motion\n  t += delta * speed * 0.0006;\n}\n\n// 1D fallback (single strip). If your strip is physically “top→bottom”,\n// direction = -1 will flip it to appear bottom→top.\nexport function render(index) {\n  var x = pixelCount > 1 ? index / (pixelCount - 1) : 0;\n  var u = x;\n\n  // apply direction flip for 1D\n  if (direction < 0) u = 1.0 - u;\n\n  var hue = fract(u * scale + t);\n  hsv(hue, 1, 1);\n}\n\n// 2D render (matrix or mapped layout)\n// vertical==1 uses y as the axis; vertical==0 uses x.\n// direction=-1 mirrors the axis so motion reads bottom→top (or right→left).\nexport function render2D(index, x, y) {\n  var u = vertical ? y : x;\n\n  // flip for bottom→top when direction = -1\n  if (direction < 0) u = 1.0 - u;\n\n  var hue = fract(u * scale + t);\n  hsv(hue, 1, 1);\n}\n\nfunction fract(v){ return v - floor(v); }"
  },
  "preview": ""
}