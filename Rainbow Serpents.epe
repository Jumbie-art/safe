{
  "name": "Rainbow Serpents",
  "id": "XWwJFZ5EspxbiFsuy",
  "sources": {
    "main": "hl = pixelCount/2\n\nexport function beforeRender(delta) {\n  t1 = time(.2)\n}\n\nexport function render(index) {\n  c = 0.1-abs(index - hl)/hl\n  c = wave(c)\n  c = wave(c + t1)\n  hsv(c,1,1)\n}"
  },
  "preview": ""
}