{
  "name": "Top to Bottom RYB",
  "id": "6o9XL63FuprW5PJGg",
  "sources": {
    "main": "export var speed = 0.3;   // 0..1\nexport var scale = 0.8;   // rainbow tightness\nvar t = 0;\n\nexport function beforeRender(delta) {\n  t += delta * speed * 0.0006; // time in seconds-ish\n}\n\nexport function render(index) {       // 1D fallback\n  var x = index / (pixelCount - 1);   // 0..1 along the strip\n  var hue = fract(x * scale + t);\n  hsv(hue, 1, 1);\n}\n\nexport function render2D(index, x, y) {  // 2D: scroll left→right\n  var hue = fract(x * scale + t);\n  hsv(hue, 1, 1);\n}\n\nfunction fract(v){ return v - floor(v); }\n"
  },
  "preview": ""
}