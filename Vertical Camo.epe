{
  "name": "Vertical Camo",
  "id": "iRZuEGze6E8QfpRGJ",
  "sources": {
    "main": "export var speed = 0.5;\nexport var scale = 1.2;\nexport var direction = 1.0; // -1 to flip diagonal\nvar t = 0;\n\nexport function beforeRender(delta) {\n  t += delta * 0.0003 * speed * direction;\n}\n\nexport function render(index) {\n  var x = index / (pixelCount - 1);\n  hsv(fract((x) * scale + t), 1, 1);\n}\n\nexport function render2D(index, x, y) {\n  var u = (x + y) * 0.5; // diagonal blend\n  hsv(fract(u * scale + t), 1, 1);\n}\n\nfunction fract(v){ return v - floor(v); }"
  },
  "preview": ""
}