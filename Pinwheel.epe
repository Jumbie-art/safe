{
  "name": "Pinwheel",
  "id": "h7yWLdWPwRh3p4i3B",
  "sources": {
    "main": "// RYB color wheel by Scruffynerf  v1.0 08-2021\n// original RYB code by Dave Eddy https://github.com/bahamas10/ryb\n// Edited to add dynamic pinwheel center sliders: centerX, centerY\n\n// === Controls (sliders) ===\nexport var wheeltype, brightness, sat\nwheeltype = 0\nbrightness = 1\nsat = 1\n\n// New center sliders (0..1). 0.5,0.5 = middle of the map.\nexport var centerX = 0.5\nexport var centerY = 0.5\n\n// (Optional) explicit slider handlers – keep simple 0..1 passthroughs\nexport function sliderWheelType(v){ wheeltype = floor(v + 0.5) }\nexport function sliderBrightness(v){ brightness = v }\nexport function sliderSaturation(v){ sat = v }\nexport function sliderCenterX(v){ centerX = v }\nexport function sliderCenterY(v){ centerY = v }\n\n// === Animation / transforms ===\nexport function beforeRender(delta) {\n  t1 = time(.19)\n  resetTransform()\n  // Move the rotation pivot to the chosen center\n  translate(-centerX, -centerY)\n  rotate(t1 * PI2)\n}\n\n// === Render ===\nexport function render2D(index, x, y) {\n  // Angle around the (translated) origin drives hue\n  a = mod(atan2(y, x) / PI2, 1)\n  if (wheeltype == 0) {\n    rybwheel(a)\n  } else {\n    hsvwheel(a)\n  }\n}\n\n// === Wheels / color helpers ===\nfunction hsvwheel(a) {\n  hsv(a, sat, brightness)\n}\n\nfunction rybwheel(a, r) {\n  // mashup of HSL and HSBRGB to approximate RYB behavior\n  v = 1 - clamp((brightness / 2), 0, 1)\n  value = sat * min(v, 1 - v) + v\n  s = value ? 2 - (2 * v / value) : 0\n  v = value\n  i = floor(a * 6)\n  f = a * 6 - i\n  q = v * (1 - (s * f))\n  t = v * (1 - (s * (1 - f)))\n  p = v * (1 - s)\n\n  if (i == 0) {\n    r = v; g = t; b = p\n  } else if (i == 1) {\n    r = q; g = v; b = p\n  } else if (i == 2) {\n    r = p; g = v; b = t\n  } else if (i == 3) {\n    r = p; g = q; b = v\n  } else if (i == 4) {\n    r = t; g = p; b = v\n  } else if (i == 5) {\n    r = v; g = p; b = q\n  }\n\n  ryb(r * r, g * g, b * b)\n}\n\nfunction ryb(R, Y, B) {\n  rgb(getR(R, Y, B), getG(R, Y, B), getB(R, Y, B))\n}\n\nfunction cubicInt(t, A, B) {\n  return A + (t * t * (3 - 2 * t)) * (B - A)\n}\n\nfunction getR(iR, iY, iB) {  // red\n  x0 = cubicInt(iB, 1, 0)\n  x1 = x0\n  x2 = 1\n  x3 = x0\n  y0 = x0\n  y1 = cubicInt(iY, x2, x3)\n  return cubicInt(iR, y0, y1)\n}\n\nfunction getG(iR, iY, iB) {  // green\n  x0 = cubicInt(iB, 1, 0)\n  x1 = 1\n  x2 = 0\n  x3 = cubicInt(iB, .5, 0)\n  y0 = cubicInt(iY, x0, x1)\n  y1 = cubicInt(iY, x2, x3)\n  return cubicInt(iR, y0, y1)\n}\n\nfunction getB(iR, iY, iB) {  // blue\n  x0 = 1\n  x1 = 0\n  x2 = cubicInt(iB, 0, 1)\n  x3 = 0\n  y0 = cubicInt(iY, x0, x1)\n  y1 = cubicInt(iY, x2, x3)\n  return cubicInt(iR, y0, y1)\n}"
  },
